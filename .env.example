# Backend (set in Render dashboard → Environment)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Existing
ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.pages.dev

# Resend – welcome email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
SIGNUP_EMAIL_REDIRECT_TO=https://localhost:5173/auth/callback

# Frontend base URL (used for logo in emails)
FRONTEND_URL=https://your-domain.pages.dev

# Supabase DB webhook shared secret (自訂一組隨機字串)
WEBHOOK_SECRET=your-random-webhook-secret
